# Application Settings
APP_NAME=Haniphei.ai API
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/haniphei

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Service settings (Integrated)
USE_LLM=True
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_actual_key_here
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
ACCURACY_TARGET=0.85

# OCR Settings
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_LANG=eng+khm

# S3/R2 Storage Configuration (Railway S3 is used)
S3_ENDPOINT_URL=https://storage.railway.app
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
S3_REGION=auto

# File Upload Configuration (in bytes)
MAX_FILE_SIZE=10485760

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
